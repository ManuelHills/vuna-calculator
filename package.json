{
  "name": "vuna-calculator",
  "version": "1.0.0",
  "description": "Oke Emmanuel Olamide — Calculator with Age Calculator Feature",
  "main": "server.js",
  "scripts": {
    "start":    "node server.js",
    "lint":     "eslint assets/js/calculator.js",
    "test":     "jest --coverage --forceExit",
    "test:ci":  "jest --coverage --ci --forceExit --coverageReporters=text"
  },
  "jest": {
    "testEnvironment": "node",
    "testMatch": ["**/tests/**/*.test.js"],
    "collectCoverageFrom": ["assets/js/calculator.js"],
    "coverageThreshold": {
      "global": {
        "lines": 80
      }
    }
  },
  "devDependencies": {
    "eslint": "^8.57.0",
    "jest":   "^29.7.0"
  }
}
